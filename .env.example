# Server Configuration
HOST=127.0.0.1
PORT=5030
DEBUG=False
WORKERS=4

# CORS Configuration
CORS_ORIGINS=["*"]

# Model Paths
EFFICIENTDET_MODEL_PATH=efficientdet_lite0.tflite
SSD_MODEL_PATH=ssd_mobilenet_v2_coco_2018_03_29
FROZEN_GRAPH_PATH=frozen_inference_graph.pb

# Detection Thresholds
BRIGHTNESS_THRESHOLD=40
BLACK_PIXEL_THRESHOLD=0.4
BLACK_THRESH_RGB=30
HIGH_EXPOSURE_THRESHOLD=245
HIGH_EXPOSURE_PERCENTAGE=30.0
FACE_MATCH_THRESHOLD=0.55
DETECTION_CONFIDENCE=0.5
FACE_BRIGHTNESS_THRESHOLD=40

# MediaPipe Configuration
MEDIAPIPE_MAX_RESULTS=5
MEDIAPIPE_SCORE_THRESHOLD=0.2

# Face Detection
MIN_FACE_DETECTION_CONFIDENCE=0.5
FACE_ENCODING_TIMEOUT=9

# Head Pose
HEAD_POSE_YAW_THRESHOLD=37
HEAD_POSE_PITCH_UP_THRESHOLD=40
HEAD_POSE_PITCH_DOWN_THRESHOLD=-37

# Eye Tracking
EYE_TRACKING_MIN_CONFIDENCE=0.6
CLOSED_EYE_THRESHOLD=0.20

# Distance Calculation
KNOWN_FACE_WIDTH_CM=14.0
FOCAL_LENGTH_PX=650
DISTANCE_OFFSET_CM=10
VALID_MIN_DISTANCE_CM=30
VALID_MAX_DISTANCE_CM=105

# Storage Paths
IMAGE_STORAGE_PATH=img
REFERENCE_IMAGE_PATH=reference_img
CACHE_DIRECTORY=cache_directory

# Process Pool
MAX_PROCESS_WORKERS=2

# API Configuration
API_V1_PREFIX=/api/v1
